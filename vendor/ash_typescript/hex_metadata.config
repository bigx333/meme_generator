{<<"name">>,<<"ash_typescript">>}.
{<<"version">>,<<"0.15.3">>}.
{<<"description">>,
 <<"Generate type-safe TypeScript clients directly from your Ash resources and actions, ensuring end-to-end type safety between your backend and frontend.">>}.
{<<"elixir">>,<<"~> 1.15">>}.
{<<"app">>,<<"ash_typescript">>}.
{<<"licenses">>,[<<"MIT">>]}.
