{
  "name": "meme-generator-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "vite build && mkdir -p ../priv/static/assets ../priv/static/app && cp -R .output/public/assets/. ../priv/static/assets/ && cp -R node_modules/.nitro/vite/services/ssr/assets/. ../priv/static/assets/ && cp .output/public/_shell.html ../priv/static/app/_shell.html",
    "dev:phoenix": "vite build --watch",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@legendapp/state": "^3.0.0-beta.30",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "nitro": "^3.0.260311-beta",
    "phoenix": "^1.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.132.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
